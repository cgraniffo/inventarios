# Copia este archivo como .env.local y completa con las claves de tu proyecto Supabase.
# Las encuentras en: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# Opcional: clave de Anthropic (Claude) para el Asistente IA.
ANTHROPIC_API_KEY=
